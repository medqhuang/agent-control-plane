# Normalize text files and keep LF for cross-platform-safe repo assets.
* text=auto

*.md text eol=lf
*.py text eol=lf
*.js text eol=lf
*.html text eol=lf
*.css text eol=lf
*.json text eol=lf
*.toml text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.txt text eol=lf

*.sh text eol=lf
*.template text eol=lf
*.service text eol=lf
*.env text eol=lf
*.env.example text eol=lf
